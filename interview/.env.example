# MockTalk — 환경변수 템플릿
# 이 파일을 `.env` 로 복사해서 실제 값을 채우세요. `.env` 는 절대 커밋하지 마세요.
#
# 셸 사용 시:
#   cp .env.example .env
#   # 그다음 본인 키로 .env 채우기

# ─── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Supabase (Storage + DB) ──────────────────────────
# 영상 업로드용 service_role 키. service_role 임에 유의 — 절대 클라이언트에 노출 X.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# Postgres 연결 (psycopg 드라이버) — Supabase 의 Transaction Pooler 사용 권장
# 예: postgresql+psycopg://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# ─── Google OAuth (선택 — 구글 로그인 사용 시) ────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── 세션 쿠키 서명 키 ────────────────────────────────
# 긴 랜덤 hex 문자열. 배포 시 반드시 교체:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=dev-secret-change-me
